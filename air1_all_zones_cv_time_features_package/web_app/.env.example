# Current lab defaults. Treat this file as containing deployment credentials.
# Copy to web_app/.env only if that file is missing.

# Model pointer. The default packaged value is:
# AIR1_ALL_ZONES_PRODUCTION_POINTER=model/production_run.txt
# This file is created by promotion. The live collector collects CSV rows and
# rebuilds the training Parquet by default; retraining and promotion are opt-in.
# A fresh package reports
# "production pointer missing" until the first real 10-second model is promoted.
RETRAIN_AFTER_PARQUET=0
RETRAIN_BOOTSTRAP_FALLBACK=auto
RETRAIN_CV_FOLDS=auto
PROMOTE_AFTER_RETRAIN=0

# Data source mode:
# live         -> query AIR-1 API directly each tick.
# parquet_tail -> read the newest parquet under AIR1_ALL_ZONES_LIVE_PARQUET_DIR.
# replay       -> advance through data\air1_all_zones_training_cv.parquet for offline testing.
AIR1_ALL_ZONES_DATA_SOURCE=live

# AIR-1 API credentials for live mode.
AIR1_API_URL=http://10.158.66.30:80
AIR1_API_KEY=9c5c3569-cfe7-42ae-bf00-e86ae08519ef

# RTSP camera and MQTT settings for run_person_counter.*.
# Run one process per camera. cam1 uses cam1-zones.json + masks/cam1-mask-zones.png;
# cam2 uses cam2-zones.json + masks/cam2-mask-zones.png. Both publish to the
# same per-zone topic.
AIR1_ALL_ZONES_RTSP_URL_CAM1=rtsp://admin:++smartilab2023@10.158.71.241:554/Streaming/channels/101
AIR1_ALL_ZONES_RTSP_URL_CAM2=rtsp://admin:++smartilab2023@10.158.71.240:554/Streaming/channels/101
AIR1_ALL_ZONES_ANNOTATED_FRAME_CAM1=data/yolo_latest_cam1.jpg
AIR1_ALL_ZONES_ANNOTATED_FRAME_CAM2=data/yolo_latest_cam2.jpg
# Set either annotated-frame value to disabled to make the web app fall back to raw RTSP for that camera.
# AIR1_ALL_ZONES_ANNOTATED_FRAME_MAX_AGE_SEC=30.0
PERSON_COUNT_MQTT_BROKER=10.158.71.19
PERSON_COUNT_MQTT_PORT=1883
PERSON_COUNT_MQTT_TOPIC=care_ssl/all_zones/person_count_by_zone
PERSON_COUNT_MQTT_USERNAME=guest
PERSON_COUNT_MQTT_PASSWORD=smartilab123

OCCUPANCY_MQTT_BROKER=10.158.71.19
OCCUPANCY_MQTT_PORT=1883
OCCUPANCY_MQTT_TOPIC=care_ssl/all_zones/person_count_by_zone
OCCUPANCY_MQTT_USERNAME=guest
OCCUPANCY_MQTT_PASSWORD=smartilab123

SEN55_MQTT_BROKER=10.158.71.19
SEN55_MQTT_PORT=1883
SEN55_MQTT_TOPIC=sen55_01/data
SEN55_MQTT_USERNAME=guest
SEN55_MQTT_PASSWORD=smartilab123

# Package-local SEN55 table used for live SEN55 model inputs. If missing, SEN55
# features are left null and the model uses training medians plus *_missing flags.
# SEN55_TABLE=data/sen55_data.csv

# Optional 10-second CV ground-truth table for dashboard comparison.
# AIR1_ALL_ZONES_CV_GROUND_TRUTH_TABLE=data/cv_occupancy_all_air1_10sec.csv

# The web app streams both YOLO-annotated camera outputs independently:
#   /api/video/cam1.mjpg and /api/video/cam2.mjpg
# /api/video.mjpg remains a cam1 compatibility alias.
AIR1_ALL_ZONES_MJPEG_TARGET_FPS=15

# Live mode tunables.
AIR1_ALL_ZONES_LIVE_LOOKBACK_SAFETY_MIN=30
# Lowered from 30 to 12 to stay under the hardened IoT1 server-side 15s cap
# (see CARE-SSL/IOT1_REMEDIATION.md §7).
AIR1_ALL_ZONES_LIVE_API_TIMEOUT_SEC=12
AIR1_ALL_ZONES_LIVE_API_RETRIES=1
AIR1_ALL_ZONES_LIVE_MAX_WORKERS=4
AIR1_ALL_ZONES_LIVE_CACHE_ENABLED=true
AIR1_ALL_ZONES_LIVE_CACHE_MAX_AGE_MIN=30
AIR1_ALL_ZONES_LIVE_CACHE_OVERLAP_MIN=2

# Parquet-tail fallback.
# AIR1_ALL_ZONES_LIVE_PARQUET_DIR=data

# Replay mode.
# AIR1_ALL_ZONES_REPLAY_PARQUET=data/air1_all_zones_training_cv.parquet
# AIR1_ALL_ZONES_REPLAY_START=2026-04-28 09:00:00

# Inference cadence and display history.
AIR1_ALL_ZONES_TICK_INTERVAL_SEC=10.0
AIR1_ALL_ZONES_HISTORY_SIZE=240

# Freshness gates passed to model inference.
AIR1_ALL_ZONES_MAX_GAP_MINUTES=5.0
AIR1_ALL_ZONES_MAX_AGE_MINUTES=15.0

# Optional probability threshold for an occupied badge.
# AIR1_ALL_ZONES_OCCUPIED_THRESHOLD=0.5

# How often the web app polls production_run.txt for model updates.
AIR1_ALL_ZONES_POINTER_POLL_SEC=30.0
AIR1_ALL_ZONES_LOG_LEVEL=INFO


