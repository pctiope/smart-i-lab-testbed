# Copy this to .env and fill in values. .env is gitignored.

# REST API
HOST_PORT=3000
ALLOWED_ORIGINS=http://localhost:5500

# PostgreSQL / TimescaleDB
DATABASE_IP=timescaledb
DATABASE_PORT=5432
DATABASE_USERNAME=ssl
DATABASE_PASSWORD=changeme
DATABASE_NAME=ssl

# EMQX
MQTT_IP=mqtt://emqx
MQTT_PORT=1883
MQTT_CLIENT_ID=ssl-iot1
MQTT_USERNAME=ssl
MQTT_PASSWORD=changeme
MQTT_RECONNECT_PERIOD=1000

# Home Assistant (Sensibo integration)
HOME_ASSISTANT_URL=http://homeassistant.local
HOME_ASSISTANT_PORT=8123
HOME_ASSISTANT_TOKEN=
