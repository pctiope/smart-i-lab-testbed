# Current lab defaults. Treat this file as containing deployment credentials.
# Copy to web_app/.env only if that file is missing.

# Model pointer. The default packaged value is:
# ZONE5_PRODUCTION_POINTER=model/production_run.txt
# This file is created by promotion. The live collector auto-promotes after
# hourly retraining when the candidate passes. A fresh package reports
# "production pointer missing" until the first real 10-second model is promoted.
PROMOTE_AFTER_RETRAIN=1

# Data source mode:
# live         -> query AIR-1 API directly each tick.
# parquet_tail -> read the newest parquet under ZONE5_LIVE_PARQUET_DIR.
# replay       -> advance through data\zone5_training_cv.parquet for offline testing.
ZONE5_DATA_SOURCE=live

# AIR-1 API credentials for live mode.
AIR1_API_URL=http://10.158.66.30:80
AIR1_API_KEY=9c5c3569-cfe7-42ae-bf00-e86ae08519ef

# RTSP camera and MQTT settings for run_person_counter.*.
# The person counter uses package-local cv_counter defaults for script, mask,
# model, and tracker config.
ZONE5_RTSP_URL=rtsp://admin:++smartilab2023@10.158.71.241:554/Streaming/channels/101
ZONE5_ANNOTATED_FRAME_PATH=data/yolo_latest.jpg
# Set ZONE5_ANNOTATED_FRAME_PATH=disabled to make the web app fall back to raw RTSP.
# ZONE5_ANNOTATED_FRAME_MAX_AGE_SEC=30.0
PERSON_COUNT_MQTT_BROKER=10.158.71.19
PERSON_COUNT_MQTT_PORT=1883
PERSON_COUNT_MQTT_TOPIC=care_ssl/zone5/person_count
PERSON_COUNT_MQTT_USERNAME=guest
PERSON_COUNT_MQTT_PASSWORD=smartilab123

OCCUPANCY_MQTT_BROKER=10.158.71.19
OCCUPANCY_MQTT_PORT=1883
OCCUPANCY_MQTT_TOPIC=care_ssl/zone5/person_count
OCCUPANCY_MQTT_USERNAME=guest
OCCUPANCY_MQTT_PASSWORD=smartilab123

SEN55_MQTT_BROKER=10.158.71.19
SEN55_MQTT_PORT=1883
SEN55_MQTT_TOPIC=sen55_01/data
SEN55_MQTT_USERNAME=guest
SEN55_MQTT_PASSWORD=smartilab123

# Package-local SEN55 table used for live SEN55 model inputs. If missing, SEN55
# features are left null and the model uses training medians plus *_missing flags.
# SEN55_TABLE=data/sen55_data.csv

# Optional 10-second CV ground-truth table for dashboard comparison.
# ZONE5_CV_GROUND_TRUTH_TABLE=data/cv_occupancy_zone5_10sec.csv

# The web app streams the YOLO-annotated frame file by default.

# Live mode tunables.
ZONE5_LIVE_LOOKBACK_SAFETY_MIN=30
# Lowered from 30 to 12 to stay under the hardened IoT1 server-side 15s cap
# (see docs/IOT1_REMEDIATION.md §7).
ZONE5_LIVE_API_TIMEOUT_SEC=12
ZONE5_LIVE_API_RETRIES=1
ZONE5_LIVE_MAX_WORKERS=4
ZONE5_LIVE_CACHE_ENABLED=true
ZONE5_LIVE_CACHE_MAX_AGE_MIN=30
ZONE5_LIVE_CACHE_OVERLAP_MIN=2

# Parquet-tail fallback.
# ZONE5_LIVE_PARQUET_DIR=data

# Replay mode.
# ZONE5_REPLAY_PARQUET=data/zone5_training_cv.parquet
# ZONE5_REPLAY_START=2026-04-28 09:00:00

# Inference cadence and display history.
ZONE5_TICK_INTERVAL_SEC=10.0
ZONE5_HISTORY_SIZE=240

# Freshness gates passed to model inference.
ZONE5_MAX_GAP_MINUTES=5.0
ZONE5_MAX_AGE_MINUTES=15.0

# Optional probability threshold for an occupied badge.
# ZONE5_OCCUPIED_THRESHOLD=0.5

# How often the web app polls production_run.txt for model updates.
ZONE5_POINTER_POLL_SEC=30.0
ZONE5_LOG_LEVEL=INFO
